<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:xFlow.ViewModels"
        x:Class="xFlow.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/logo.png"
        Title="xFlow"
        FontFamily="Segoe UI, Inter, sans-serif"
        Background="#1E1E1E">
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Background="#333333" BorderBrush="#444" BorderThickness="0,0,0,1">
            <StackPanel>
                <Border Background="#333333" Padding="8,8">
                    <StackPanel Orientation="Horizontal" Spacing="15">
                        <StackPanel Spacing="5">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="btn-menu">
                                    <Image Source="/Assets/excel.png"/>
                                </Button>
                                <Button Classes="btn-menu">
                                    <Image Source="/Assets/word.png"/>
                                </Button>
                                <Button Classes="btn-menu">
                                    <Image Source="/Assets/json.png"/>
                                </Button>
                                <Button Classes="btn-menu">
                                    <Image Source="/Assets/setting.png"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                        <Border Width="1" Background="#444" Height="32" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="1" Margin="10" VerticalAlignment="Top">
            <Border CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="#555"
                    ClipToBounds="True"
                    Margin="10" 
                    Padding="0,0,0,2"  
                    VerticalAlignment="Top">
                <DataGrid ItemsSource="{Binding YourDataList}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Cột 1" Binding="{Binding Column1Property}" Width="*" />
                        <DataGridTextColumn Header="Cột 2" Binding="{Binding Column2Property}" Width="*" />
                        <DataGridTemplateColumn Width="120">
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Classes="text-action" Text="Thao tác"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                VerticalAlignment="Center" Spacing="12">
                                        <Button Classes="btn-action">
                                            <Image Source="avares://xFlow/Assets/view.png"/>
                                        </Button>
                                        <Button Classes="btn-action">
                                            <Image Source="avares://xFlow/Assets/edit.png"/>
                                        </Button>
                                        <Button Classes="btn-action">
                                            <Image Source="avares://xFlow/Assets/remove.png"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Spacing="5" 
                        Margin="0,10,0,0">
            
                <Button Classes="btn-pagination" Content="&lt;"/> <Button Classes="btn-pagination active" Content="1"/>
                <Button Classes="btn-pagination" Content="2"/>
                <Button Classes="btn-pagination" Content="3"/>
                <TextBlock Text="..." Foreground="White" VerticalAlignment="Center" Margin="5,0"/>
                <Button Classes="btn-pagination" Content="10"/>
            
                <Button Classes="btn-pagination" Content="&gt;"/> 
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>