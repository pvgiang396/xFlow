<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:xFlow.ViewModels"
        x:Class="xFlow.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/logo.png"
        Title="xFlow"
        FontFamily="Segoe UI, Inter, sans-serif"
        Background="#1E1E1E">
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Background="#333333" BorderBrush="#444" BorderThickness="0,0,0,1">
            <StackPanel>
                <Border Background="#333333" Padding="8,8">
                    <StackPanel Orientation="Horizontal" Spacing="15">
                        <StackPanel Spacing="5">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button
                                    Background="Transparent"
                                    Padding="0"
                                    Cursor="Hand"
                                    BorderThickness="0">
                                    <Image Source="/Assets/excel.png" Stretch="Uniform" />
                                </Button>
                                <Button
                                    Background="Transparent"
                                    Padding="0"
                                    Cursor="Hand"
                                    BorderThickness="0">
                                    <Image Source="/Assets/word.png" Stretch="Uniform" />
                                </Button>
                                <Button
                                    Background="Transparent"
                                    Padding="0"
                                    Cursor="Hand"
                                    BorderThickness="0">
                                    <Image Source="/Assets/json.png" Stretch="Uniform" />
                                </Button>
                                <Button
                                    Background="Transparent"
                                    Padding="0"
                                    Cursor="Hand"
                                    BorderThickness="0">
                                    <Image Source="/Assets/setting.png" Stretch="Uniform" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                        <Border Width="1" Background="#444" Height="32" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
        <Grid Grid.Row="1" Margin="20">
            <Border CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="#555"
                    ClipToBounds="True"
                    Margin="10">
                <DataGrid ItemsSource="{Binding YourDataList}"
                          AutoGenerateColumns="False"
                          GridLinesVisibility="Vertical"
                          VerticalGridLinesBrush="#444"
                          Background="Transparent"
                          IsReadOnly="True"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Cột 1" Binding="{Binding Column1Property}" Width="*" />
                        <DataGridTextColumn Header="Cột 2" Binding="{Binding Column2Property}" Width="*" />
                        <DataGridTemplateColumn Width="120">
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="Thao tác"
                                               Margin="18 0 0 0"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                VerticalAlignment="Center" Spacing="12">
                                        <Button Background="Transparent" BorderThickness="0" Padding="0">
                                            <Image Source="avares://xFlow/Assets/view.png" Width="16" Height="16" />
                                        </Button>
                                        <Button Background="Transparent" BorderThickness="0" Padding="0">
                                            <Image Source="avares://xFlow/Assets/edit.png" Width="16" Height="16" />
                                        </Button>
                                        <Button Background="Transparent" BorderThickness="0" Padding="0">
                                            <Image Source="avares://xFlow/Assets/remove.png" Width="16" Height="16" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>