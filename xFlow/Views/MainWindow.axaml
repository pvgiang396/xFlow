<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:xFlow.ViewModels"
        x:Class="xFlow.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/logo.png"
        Title="xFlow"
        FontFamily="Segoe UI, Inter, sans-serif"
        Background="#1E1E1E">
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Background="#333333" BorderBrush="#444" BorderThickness="0,0,0,1">
            <StackPanel>
                <Border Background="#333333" Padding="8,8">
                    <StackPanel Orientation="Horizontal" Spacing="15">
                        <StackPanel Spacing="5">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button
                                        Background="Transparent"
                                        Padding="0"
                                        Cursor="Hand"
                                        BorderThickness="0">
                                    <Image Source="/Assets/json.png" Stretch="Uniform"/>
                                </Button>
                                <Button
                                    Background="Transparent"
                                    Padding="0"
                                    Cursor="Hand"
                                    BorderThickness="0">
                                    <Image Source="/Assets/setting.png" Stretch="Uniform"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                        <Border Width="1" Background="#444" Height="32"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
        <Grid Grid.Row="1" Margin="20">
            <Border BorderThickness="1" BorderBrush="#AAAAAA" 
                    Background="#2D2D2D" CornerRadius="5" 
                    HorizontalAlignment="Stretch" VerticalAlignment="Top" 
                    Padding="0">
                 <DataGrid ItemsSource="{Binding YourDataList}" 
                           AutoGenerateColumns="False"
                           CanUserResizeColumns="True"
                           GridLinesVisibility="All" 
                           HorizontalGridLinesBrush="#555"
                           VerticalGridLinesBrush="#555"
                           RowBackground="#252525"
                           RowHeight="30"
                           Background="Transparent"
                           IsReadOnly="True"
                           BorderThickness="0">
        
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Cột 1" Binding="{Binding Column1Property}" Width="*" />
                        <DataGridTextColumn Header="Cột 2" Binding="{Binding Column2Property}" Width="*" />
                        <DataGridTextColumn Header="Cột 3" Binding="{Binding Column3Property}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>