<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:xFlow.ViewModels"
        x:Class="xFlow.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/mapping.png"
        Title="xFlow Automation"
        FontFamily="Segoe UI, Inter, sans-serif"
        Background="#1e1e1e">
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Background="#333333" BorderBrush="#444" BorderThickness="0,0,0,1">
            <StackPanel>
                <Border Background="#222" Padding="20,8">
                    <TextBlock Text="xFlow Automation Tool" Foreground="#aaaaaa" FontSize="16" FontWeight="Bold"/>
                </Border>
                <Border Background="#333333" Padding="8,8">
                    <StackPanel Orientation="Horizontal" Spacing="15">
                        <StackPanel Spacing="5">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Width="32" Height="32" Background="#c24941">
                                    <TextBlock Text="D" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                                <Button Width="32" Height="32" Background="#6a539c">
                                    <TextBlock Text="M" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                        <Border Width="1" Background="#444" Height="32"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
        <Grid Grid.Row="1" Margin="20">
            <TextBlock Text="Main Workspace" Foreground="#333" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>